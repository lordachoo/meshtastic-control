{
  "enabled": true,
  "rules": [
    {
      "id": "ping",
      "enabled": true,
      "trigger": "ping",
      "triggerType": "exact",
      "response": "pong from {sender_short} ({sender_name} / {sender_id})",
      "messageType": "both",
      "sourceType": "both",
      "cooldownSeconds": 60
    },
    {
      "id": "test",
      "enabled": true,
      "trigger": "test",
      "triggerType": "contains",
      "response": "test received: {sender_short} ({sender_name} / {sender_id})",
      "messageType": "both",
      "sourceType": "both",
      "cooldownSeconds": 300
    },
    {
      "id": "rf_only_test",
      "enabled": true,
      "trigger": "rf test",
      "triggerType": "exact",
      "response": "RF test received from {sender_short}",
      "messageType": "both",
      "sourceType": "rf",
      "cooldownSeconds": 300
    },
    {
      "id": "mqtt_only_test",
      "enabled": false,
      "trigger": "mqtt test",
      "triggerType": "exact",
      "response": "MQTT test received from {sender_short}",
      "messageType": "both",
      "sourceType": "mqtt",
      "cooldownSeconds": 300
    }
  ],
  "available_variables": {
    "{sender_name}": "Full name of the sender (e.g., 'John Doe')",
    "{sender_short}": "Short name of the sender (e.g., 'JD')",
    "{sender_id}": "Node ID of the sender (e.g., '!02ed4dfc')",
    "{my_name}": "Your node's full name",
    "{my_id}": "Your node's ID",
    "{message}": "The original message text",
    "{message_type}": "Either 'broadcast' or 'direct'",
    "{source_type}": "Either 'RF' or 'MQTT'",
    "{hops}": "Number of hops the message traveled"
  }
}
